# =============================================================
# Pugmill Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# --- Database ---
# PostgreSQL connection string.
# Local:           postgresql://username@localhost:5432/pugmill
# Neon:            Get from your Neon project dashboard
# Supabase:        Get from Project Settings → Database → Connection string (pooler)
# Railway/Render:  Provided automatically when you add a PostgreSQL service
# Vercel+Supabase: The integration injects POSTGRES_URL automatically —
#                  DATABASE_URL is not required when POSTGRES_URL is present.
DATABASE_URL=

# --- NextAuth ---
# Generate a secret: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=
# Full URL of your app (no trailing slash)
# Local dev:   http://localhost:3000
# Production:  https://your-domain.com
NEXTAUTH_URL=

# --- GitHub OAuth (optional) ---
# Create an OAuth App at: https://github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google OAuth (optional) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Media Storage ---
# STORAGE_PROVIDER controls where uploaded media files are saved.
# Options: "local" (default) | "vercel-blob" | "s3"
#
#   local        — saves to /public/uploads on the server filesystem.
#                  Works for local dev and servers with persistent storage (Replit).
#                  NOT suitable for ephemeral/serverless platforms (Vercel, etc.).
#
#   vercel-blob  — uploads to Vercel Blob storage.
#                  Easiest option for Vercel deployments — no extra accounts needed.
#                  Add the Blob integration in your Vercel project to get the token.
#                  Requires: BLOB_READ_WRITE_TOKEN
#
#   s3           — uploads to any S3-compatible object store.
#                  Works on any platform. Supports AWS S3, Cloudflare R2,
#                  DigitalOcean Spaces, MinIO.
STORAGE_PROVIDER=local

# --- Vercel Blob (required when STORAGE_PROVIDER=vercel-blob) ---
# Generated automatically when you add the Vercel Blob integration.
# Vercel project dashboard → Storage → Create Database → Blob
BLOB_READ_WRITE_TOKEN=

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# AWS S3 example:
#   S3_BUCKET=my-pugmill-media
#   S3_REGION=us-east-1
#   S3_ACCESS_KEY_ID=AKIAxxxxxxxxxxx
#   S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   S3_PUBLIC_URL=https://my-pugmill-media.s3.us-east-1.amazonaws.com
#
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_PUBLIC_URL=https://pub-xxxx.r2.dev   (or your custom R2 domain)
#
# DigitalOcean Spaces example:
#   S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
#   S3_REGION=nyc3
#   S3_PUBLIC_URL=https://my-bucket.nyc3.cdn.digitaloceanspaces.com
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

# --- AI Integration ---
# Encrypts the AI provider API key stored in the database (AES-256-GCM).
# Generate with: openssl rand -hex 32
# Optional — if not set, the key is stored as plaintext with a server warning.
AI_ENCRYPTION_KEY=

# --- Pugmill Intelligence Network (optional) ---
# Required only if you are running the /api/ingest endpoint to receive
# aggregated bot analytics from other Pugmill sites.
# Generate with: openssl rand -hex 32
PUGMILL_NETWORK_SECRET=

# --- First-run Setup ---
# Used by `npm run setup` to create the initial admin account
# Can be set here for automated/agent setups, or entered interactively
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# =============================================================
# Secrets Management Recommendations
# =============================================================
# Vercel:          Environment Variables in project settings
# Railway/Render:  Environment Variables dashboard
# Local dev:       .env.local (gitignored — never commit this)
# Self-hosted:     Doppler (https://doppler.com) or
#                  Infisical (https://infisical.com)
# =============================================================
