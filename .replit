# Pugmill CMS — Replit Configuration
modules = ["nodejs-22", "typescript-default", "postgresql-16"]

# Start the dev server (predev runs replit-init automatically on first boot)
run = "npm run dev"

entrypoint = "src/app/page.tsx"

[nix]
channel = "stable-24_05"

[deployment]
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[languages.typescript]
pattern = "**/*.{ts,tsx}"

[languages.typescript.languageServer]
start = "typescript-language-server --stdio"

[webserver]
port = 3000

# ─── Required Secrets ────────────────────────────────────────────────────────
# DATABASE_URL is provided automatically by Replit's PostgreSQL integration.
# NEXTAUTH_SECRET and NEXTAUTH_URL are auto-generated by replit-init on first run.
# You do NOT need to set them manually.
#
# Optional — to pre-configure the admin account before first run:
#   ADMIN_EMAIL    (default: admin@pugmill.local)
#   ADMIN_PASSWORD (default: auto-generated, printed to console on first run)
#   ADMIN_NAME     (default: Admin)

# ─── Helper Actions ───────────────────────────────────────────────────────────
[[hints]]
text = "First-Run Setup"
command = "npm run replit:init"

[[hints]]
text = "Create / Reset Database Schema"
command = "npm run db:create"

[[hints]]
text = "Open Database Studio"
command = "npm run db:studio"

# ─── Environment ──────────────────────────────────────────────────────────────
[env]
NODE_ENV = "development"
NEXT_TELEMETRY_DISABLED = "1"
